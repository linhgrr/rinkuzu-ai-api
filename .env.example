ENVIRONMENT=dev
LOAD_MODELS=true
CORS_ORIGINS=["http://localhost:3000"]
INTERNAL_SERVICE_TOKEN=replace-me
LOG_LEVEL=INFO

MONGODB_URI=mongodb://localhost:27017

# LLM provider (current demo target: DeepSeek via LiteLLM/OpenAI-compatible API)
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=your-model-name
LLM_API_KEY=replace-me
LLM_CUSTOM_PROVIDER=openai
EXERCISE_LLM_MODEL=
LLM_EMBEDDING_MODEL=text-embedding-3-small

# OCR provider (current demo target: LandingAI ADE Parse)
OCR_BASE_URL=https://api.va.landing.ai/v1/ade/parse
OCR_MODEL=dpt-2-mini
OCR_API_KEY=replace-me
OCR_TIMEOUT_SEC=120

# PDF extraction / batching
CONTENT_PIPELINE_PDF_PAGE_BATCH_SIZE=10
CONTENT_PIPELINE_PDF_BATCH_MAX_BYTES=4194304
CONTENT_PIPELINE_BATCH_FAILURE_RATIO_THRESHOLD=0.5
CONTENT_PIPELINE_LLM_REQUEST_TIMEOUT_SEC=180

# Object storage / S3-compatible cache
OBJECT_STORAGE_REGION=ap-southeast-1
OBJECT_STORAGE_ENDPOINT_EXTERNAL=http://localhost:9000
OBJECT_STORAGE_ENDPOINT_INTERNAL=
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=rinkuzu
OBJECT_STORAGE_ADDRESSING_STYLE=path
